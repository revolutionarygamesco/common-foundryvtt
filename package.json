{
  "name": "@revolutionarygamesco/common-foundryvtt",
  "description": "A library of methods and types that we tend to use in all (or at least most) of our Foundry VTT modules.",
  "version": "0.2.0",
  "homepage": "https://github.com/revolutionarygamesco/common-foundryvtt",
  "bugs": "https://github.com/revolutionarygamesco/common-foundryvtt/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/revolutionarygamesco/common-foundryvtt.git"
  },
  "license": "GPL-3.0-or-later",
  "contributors": [
    {
      "name": "Jason Godesky",
      "email": "jason@revolutionarygames.co"
    }
  ],
  "funding": {
    "type": "patreon",
    "url": "https://patreon.com/revolutionarygamesco"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./mocks": {
      "types": "./dist/mocks/index.d.mts",
      "default": "./dist/mocks/index.mjs"
    },
    "./mocks/setup": {
      "types": "./dist/mocks/setup.d.mts",
      "default": "./dist/mocks/setup.mjs"
    },
    "./systems/*": {
      "types": "./dist/foundry/systems/*.d.mts",
      "default": "./dist/foundry/systems/*.mjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "./dist/foundry/systems/*.mjs",
    "./dist/mocks/setup.mjs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "vitest": "^4.1.10"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "scripts": {
    "test": "vitest run && npm run test:types",
    "test:types": "tsc --noEmit && node scripts/typecheck-systems.mjs",
    "test:coverage": "vitest run --coverage",
    "build": "tsdown",
    "prepack": "npm_config_dry_run=false npm run build",
    "prepublishOnly": "npm run test"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@vitest/coverage-v8": "^4.1.10",
    "publint": "^0.3.21",
    "tsdown": "^0.22.5",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@revolutionarygamesco/common": "^1.1.0"
  }
}
